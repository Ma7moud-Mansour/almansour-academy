# PostgreSQL (local, Supabase, Neon, or PostgreSQL on Hostinger VPS)
DATABASE_URL=postgresql://postgres:password@localhost:5432/almansour_academy

# Used once to create the first super-admin from /admin/login.
ADMIN_BOOTSTRAP_NAME='Mahmoud Abdelkareem'
ADMIN_BOOTSTRAP_EMAIL=mahmoud@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-this-to-a-long-random-password

# Resend email verification (use a sender on a domain verified in Resend)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL='أكاديمية المنصور <accounts@your-domain.com>'
